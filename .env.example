# ── Supabase ────────────────────────────────────────────────────────────────
# 未設定の場合、アプリはモックデータ（design モック相当）で動作します。
# 設定すると Supabase の実データを読み書きします。

# クライアント（ブラウザ）公開値。anon キーは RLS で書き込み全面拒否・読み取りのみ。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー専用。Route Handler / Server Action からの書き込みに使用。
# 絶対にクライアントへ露出させない（NEXT_PUBLIC_ を付けない）。
SUPABASE_SERVICE_ROLE_KEY=

# ── Excel 初期インポート（scripts/seed-from-excel.ts）────────────────────────
# 取り込む Excel のパス（同梱: NEO_ACADEMIA_拠点展開ターゲットリスト.xlsx）
SEED_EXCEL_PATH=./NEO_ACADEMIA_拠点展開ターゲットリスト.xlsx
